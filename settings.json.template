{
  "env": {
    "ANTHROPIC_MODEL": "databricks-claude-opus-4-5",
    "ANTHROPIC_BASE_URL": "https://YOUR_WORKSPACE.cloud.databricks.com/serving-endpoints/anthropic",
    "ANTHROPIC_AUTH_TOKEN": "YOUR_DATABRICKS_PAT_TOKEN",
    "ANTHROPIC_CUSTOM_HEADERS": "x-databricks-use-coding-agent-mode: true"
  },
  "permissions": {
    "allow": [
      "Bash(date:*)",
      "Bash(echo:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(sort:*)",
      "Bash(grep:*)",
      "Bash(tr:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git tag:*)",
      "Edit(//tmp/**)",
      "Edit(~/.vibe/**)",
      "Edit(~/code/**)",
      "Read(//tmp/**)",
      "Read(~/**)",
      "Read(~/.claude/**)",
      "Read(~/.vibe/**)",
      "Read(~/code/**)",
      "Skill",
      "Skill(aws-authentication)",
      "Skill(configure-vibe)",
      "Skill(databricks-authentication)",
      "Skill(databricks-demo)",
      "Skill(databricks-query)",
      "Skill(databricks-resource-deployment)",
      "Skill(databricks-warehouse-selector)",
      "Skill(databricks-workspace-deployment)",
      "Skill(gdocs-utility)",
      "Skill(genie-rooms)",
      "Skill(google-docs)",
      "Skill(logfood-querier)",
      "Skill(salesforce-actions)",
      "Skill(salesforce-authentication)",
      "Write(//tmp/**)",
      "Write(~/.vibe/**)",
      "Write(~/code/**)",
      "mcp__proxy__slack__slack_write_api_call"
    ],
    "deny": []
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/gsd-check-update.js\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node \"$HOME/.claude/hooks/gsd-statusline.js\""
  },
  "enabledPlugins": {
    "fe-databricks-tools@fe-vibe": true,
    "fe-salesforce-tools@fe-vibe": true,
    "fe-google-tools@fe-vibe": true,
    "fe-specialized-agents@fe-vibe": true,
    "fe-internal-tools@fe-vibe": true,
    "fe-vibe-setup@fe-vibe": true,
    "fe-mcp-servers@fe-vibe": true,
    "fe-jira-tools@fe-vibe": true,
    "fe-file-expenses@fe-vibe": true,
    "fe-workflows@fe-vibe": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "frontend-design@claude-code-plugins": true
  },
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "YOUR_CONTEXT7_API_KEY"
      ]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "chrome-devtools-mcp@latest",
        "--userDataDir=~/.vibe/chrome/profile"
      ]
    },
    "glean": {
      "command": "python3.10",
      "args": [
        "~/mcp/servers/glean_mcp/glean_mcp_deploy.pex"
      ],
      "env": {
        "I_DANGEROUSLY_OPT_IN_TO_UNSUPPORTED_ALPHA_TOOLS": "true"
      },
      "type": "stdio"
    },
    "google": {
      "command": "python3.10",
      "args": [
        "~/mcp/servers/google_mcp/google_mcp_deploy.pex"
      ],
      "env": {
        "GOOGLE_MCP_WRITE_ENABLED": "true",
        "I_DANGEROUSLY_OPT_IN_TO_UNSUPPORTED_ALPHA_TOOLS": "true"
      },
      "type": "stdio"
    },
    "jira": {
      "command": "python3.10",
      "args": [
        "~/mcp/servers/jira_mcp/jira_mcp_deploy.pex"
      ],
      "env": {
        "I_DANGEROUSLY_OPT_IN_TO_UNSUPPORTED_ALPHA_TOOLS": "true"
      },
      "type": "stdio"
    },
    "slack": {
      "command": "python3.10",
      "args": [
        "~/mcp/servers/slack_mcp/slack_mcp_deploy.pex"
      ],
      "env": {
        "I_DANGEROUSLY_OPT_IN_TO_UNSUPPORTED_ALPHA_TOOLS": "true"
      },
      "type": "stdio"
    }
  },
  "allow": [
    "Bash",
    "Bash(cat:*)",
    "Bash(date:*)",
    "Bash(echo:*)",
    "Bash(git add:*)",
    "Bash(git commit:*)",
    "Bash(git diff:*)",
    "Bash(git log:*)",
    "Bash(git status:*)",
    "Bash(git tag:*)",
    "Bash(grep:*)",
    "Bash(head:*)",
    "Bash(ls:*)",
    "Bash(mkdir:*)",
    "Bash(sort:*)",
    "Bash(tail:*)",
    "Bash(tr:*)",
    "Bash(wc:*)",
    "Edit(//tmp/**)",
    "Edit(~/.vibe/**)",
    "Edit(~/code/**)",
    "Read(//tmp/**)",
    "Read(~/**)",
    "Read(~/.claude/**)",
    "Read(~/.vibe/**)",
    "Read(~/code/**)",
    "Skill",
    "Skill(aws-authentication)",
    "Skill(build-vibe-skill)",
    "Skill(configure-vibe)",
    "Skill(databricks-apps)",
    "Skill(databricks-authentication)",
    "Skill(databricks-demo)",
    "Skill(databricks-fe-vm-workspace-deployment)",
    "Skill(databricks-lakebase)",
    "Skill(databricks-lakeview-dashboard)",
    "Skill(databricks-oneenv-workspace-deployment)",
    "Skill(databricks-query)",
    "Skill(databricks-resource-deployment)",
    "Skill(databricks-sizing)",
    "Skill(databricks-troubleshooting)",
    "Skill(databricks-warehouse-selector)",
    "Skill(databricks-workspace-deployment)",
    "Skill(draft-rca)",
    "Skill(emburse-expenses)",
    "Skill(fe-account-transition)",
    "Skill(fe-answer-customer-questions)",
    "Skill(fe-databricks-feature-tester)",
    "Skill(fe-poc-postmortem)",
    "Skill(fe-snowflake)",
    "Skill(fe-todo-list)",
    "Skill(file-expenses)",
    "Skill(genie-rooms)",
    "Skill(gmail)",
    "Skill(google-auth)",
    "Skill(google-calendar)",
    "Skill(google-docs)",
    "Skill(google-sheets-creator)",
    "Skill(google-slides-creator)",
    "Skill(jira-actions)",
    "Skill(logfood-querier)",
    "Skill(performance-tuning)",
    "Skill(poc-doc)",
    "Skill(product-question-research)",
    "Skill(salesforce-actions)",
    "Skill(salesforce-authentication)",
    "Skill(security-questionnaire)",
    "Skill(support-escalation)",
    "Skill(uco-consumption-analysis)",
    "Skill(uco-updates)",
    "Skill(validate-mcp-access)",
    "Skill(vibe-update)",
    "Write(//tmp/**)",
    "Write(~/.vibe/**)",
    "Write(~/code/**)",
    "mcp__proxy__glean__glean_read_api_call",
    "mcp__proxy__glean__glean_write_api_call",
    "mcp__proxy__slack__slack_write_api_call"
  ]
}
